rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Public ────────────────────────────────────────────────────────────────
    match /public/{document=**} {
      allow read: if true;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId} {
      allow read, write: if request.auth.token.email == 'ishanhatharasinghe222@gmail.com';
    }

    // ── Posts ──────────────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow get: if resource.data.status == 'approved' ||
                 request.auth != null && (
                   request.auth.uid == resource.data.serviceProviderId ||
                   request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                 );
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
                    request.resource.data.serviceProviderId == request.auth.uid &&
                    request.resource.data.status == 'pending';
      allow update: if request.auth != null && (
                      request.auth.uid == resource.data.serviceProviderId ||
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                    ) && (
                      resource.data.status == 'pending' ||
                      resource.data.status == 'draft' ||
                      resource.data.status == 'rejected' ||
                      resource.data.status == 'approved' ||
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                    );
      allow delete: if request.auth != null &&
              request.auth.uid == resource.data.serviceProviderId;
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow get: if resource.data.status == 'active';
      allow list: if request.auth != null;
      allow create: if request.auth != null &&
                    request.resource.data.reviewerId == request.auth.uid &&
                    request.resource.data.rating >= 1 &&
                    request.resource.data.rating <= 5 &&
                    request.resource.data.comment != "" &&
                    request.resource.data.comment.size() > 0 &&
                    request.resource.data.reviewerId != request.resource.data.serviceProviderId;
      allow update: if request.auth != null && (
                      // REACTIONS: ANY authenticated user (seeker, provider, admin) can toggle reactions
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'updatedAt']) ||
                      // CONTENT EDITS: Only reviewer or admin can edit review comment/rating
                      (request.auth.uid == resource.data.reviewerId ||
                       request.auth.token.email == 'ishanhatharasinghe222@gmail.com')
                    );
      allow delete: if request.auth != null && (
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com' ||
                      request.auth.uid == resource.data.reviewerId ||
                      request.auth.uid == resource.data.serviceProviderId
                    );
    }

    // ── Admin logs ────────────────────────────────────────────────────────────
    match /admin_logs/{logId} {
      allow read, write: if request.auth.token.email == 'ishanhatharasinghe222@gmail.com';
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow get: if request.auth != null &&
                 request.auth.uid == resource.data.recipientId;
      allow list: if request.auth != null;
      allow create: if request.auth != null && (
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com' ||
                      request.resource.data.type == 'new_message' ||
                      request.resource.data.type == 'booking_request' ||
                      request.resource.data.type in ['booking_approved', 'booking_declined', 'booking_cancelled']
                    );
      allow update: if request.auth != null && (
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com' ||
                      (
                        request.auth.uid == resource.data.recipientId &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
                      )
                    );
      allow delete: if request.auth != null && (
                      request.auth.uid == resource.data.recipientId ||
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                    );
    }

    // ── Bookings ───────────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Read: customer, provider, or admin
      allow get: if request.auth != null &&
                 (request.auth.uid == resource.data.customerId ||
                  request.auth.uid == resource.data.providerId ||
                  request.auth.token.email == 'ishanhatharasinghe222@gmail.com');
      
      // List: any authenticated user (client-side filtered by customerId/providerId)
      allow list: if request.auth != null;
      
      // Create: any authenticated user can create bookings for themselves, or admin can create for anyone
      allow create: if request.auth != null && (
                    (request.auth.uid == request.resource.data.customerId &&
                     request.resource.data.status == 'pending' &&
                     request.resource.data.customerId != null &&
                     request.resource.data.providerId != null &&
                     request.resource.data.bookingDate != null) ||
                    request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                   );
      
      // Update: provider approves/declines, customer cancels/completes, admin can do all
      // Helper function to check if user is admin
      allow update: if request.auth != null && (
                      // Provider: approve pending bookings
                      (request.auth.uid == resource.data.providerId &&
                       request.resource.data.status == 'approved' &&
                       resource.data.status == 'pending' &&
                       // Provider cannot modify other fields when approving
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      // Provider: decline pending bookings (with reason)
                      (request.auth.uid == resource.data.providerId &&
                       request.resource.data.status == 'declined' &&
                       resource.data.status == 'pending' &&
                       request.resource.data.declinedReason != null &&
                       request.resource.data.declinedReason.size() > 0 &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'declinedReason', 'updatedAt'])) ||
                      // Provider: decline approved bookings (with reason)
                      (request.auth.uid == resource.data.providerId &&
                       request.resource.data.status == 'declined' &&
                       resource.data.status == 'approved' &&
                       request.resource.data.declinedReason != null &&
                       request.resource.data.declinedReason.size() > 0 &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'declinedReason', 'updatedAt'])) ||
                      // Provider: cancel approved bookings (with reason)
                      (request.auth.uid == resource.data.providerId &&
                       request.resource.data.status == 'cancelled' &&
                       resource.data.status == 'approved' &&
                       request.resource.data.cancellationReason != null &&
                       request.resource.data.cancellationReason.size() > 0 &&
                       request.resource.data.cancelledBy == 'provider' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason', 'cancelledBy', 'updatedAt'])) ||
                      // Customer: cancel pending bookings
                      (request.auth.uid == resource.data.customerId &&
                       request.resource.data.status == 'cancelled' &&
                       resource.data.status == 'pending' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      // Customer: cancel approved bookings (with reason)
                      (request.auth.uid == resource.data.customerId &&
                       request.resource.data.status == 'cancelled' &&
                       resource.data.status == 'approved' &&
                       request.resource.data.cancellationReason != null &&
                       request.resource.data.cancellationReason.size() > 0 &&
                       request.resource.data.cancelledBy in ['customer', 'admin'] &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'cancellationReason', 'cancelledBy', 'updatedAt'])) ||
                      // Customer: mark completed on approved bookings
                      (request.auth.uid == resource.data.customerId &&
                       request.resource.data.status == 'completed' &&
                       resource.data.status == 'approved' &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
                      // Admin: full control
                      request.auth.token.email == 'ishanhatharasinghe222@gmail.com'
                    );
      
      // Delete: customer or admin (soft-delete via cancel recommended)
      allow delete: if request.auth != null &&
                    (request.auth.token.email == 'ishanhatharasinghe222@gmail.com' ||
                     request.auth.uid == resource.data.customerId);
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    match /conversations/{conversationId} {
      // Allow any authenticated user to `get` a conversation document.
      //
      // WHY: The service uses getDoc() to check whether a conversation already
      // exists before creating it (getOrCreateConversation).  When the document
      // does NOT exist, `resource` is null — so checking
      // `request.auth.uid in resource.data.participantIds` crashes the rule
      // evaluation and Firestore returns "Missing or insufficient permissions"
      // even though the intent is simply to read a non-existent document.
      //
      // Keeping get open to all authenticated users is safe: the document
      // payload is only meaningful to the two participants, and an outsider
      // reading it gains nothing actionable (no messages are stored here).
      allow get: if request.auth != null;

      // Any authenticated user can list (client-side filtered by participantIds)
      allow list: if request.auth != null;

      // Creating: must be one of the two participants
      allow create: if request.auth != null &&
                    request.auth.uid in request.resource.data.participantIds;

      // Updating: must be a participant.
      // Covers:
      //   a) Sending a message (updates lastMessage / lastMessageTime / deletedBy reset)
      //   b) Soft-delete ("Delete for me") — only allowed to touch deletedBy,
      //      lastMessage, lastMessageTime, updatedAt, and participants fields.
      //   c) Restoring a previously-deleted conversation when re-opening chat.
      allow update: if request.auth != null &&
                    request.auth.uid in resource.data.participantIds;

      // Hard delete: participant only (admin use / legacy)
      allow delete: if request.auth != null &&
                    request.auth.uid in resource.data.participantIds;

      // ── Messages subcollection ──────────────────────────────────────────────
      match /messages/{messageId} {
        allow get: if request.auth != null &&
                   request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow list: if request.auth != null &&
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if request.auth != null &&
                      request.auth.uid == request.resource.data.senderId &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update: if request.auth != null &&
                      request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        // Messages are never hard-deleted (soft-delete at conversation level)
        allow delete: if false;
      }
    }
  }
}
